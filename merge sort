class Solution {
  public:
    void mergeSort(vector<int>& arr, int l, int r) {
        // code here
        //basically we are dividing the array into two halves and sorting them recursively. Then we are merging the two halves in sorted order. Time complexity is O(nlogn) in all cases and space complexity is O(n) due to the temporary arrays used for merging.
        // The merge function is used to merge two halves of the array in sorted order. We are creating two temporary arrays to store the left and right halves of the array. Then we are comparing the elements of the two halves and merging them in sorted order. Finally we are copying the merged array back to the original array.
        if(l>=r)
        return;
        int mid = l +(r - l)/2;
        
        mergeSort(arr, l, mid);
        mergeSort(arr, mid+1, r);
        merge(arr, l,mid, r);
        
    }
    public:
    void merge(vector<int>&arr, int l, int mid, int r){
         
        int n1 = mid-l+1;
        int n2 = r-mid;
        
        vector<int> arr1(n1), arr2(n2);
        
        int i;
        int j;
        int k = l;
        
        for(i = 0; i<n1; i++){
            arr1[i]=arr[l + i];
            
        }
        for(j = 0; j<n2; j++){
            arr2[j]=arr[mid+j+1];
            
        }
        i = 0, j = 0, k = l; 
        
        while(i<n1 && j<n2){
            if(arr1[i]<arr2[j]){
                arr[k] = arr1[i];
                i++;
            }
            else{
                arr[k]= arr2[j];
                j++;
            }
            
            k++;
        }
        while(i<n1){
            arr[k]=arr1[i];
            i++;
            k++;
        }
         while(j<n2){
            arr[k]=arr2[j];
            j++;
            k++;
        }
    }
};