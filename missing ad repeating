class Solution {
  public:
    vector<int> findTwoElement(vector<int>& arr) {
        // code here
        //basically we are using a hash map to count the frequency of each element in the array. Then we are iterating through the hash map to find the repeating and missing elements. Time complexity is O(n) and space complexity is O(n) due to the hash map.
        unordered_map<int, int> nums;
        int a = 0, b = 0;
        for(int i =0; i<arr.size(); i++){
            nums[arr[i]]++;
        }
        for(int j = 1; j<=arr.size(); j++){
            if(nums[j] >1){
            a = j;
            }
            else if(nums[j] == 0)
            b = j;
        }
        return {a, b};
    }
};