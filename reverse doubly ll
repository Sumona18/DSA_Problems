*/
class Solution {
  public:
    Node *reverse(Node *head) {
        // code here
       Node* current = head;
        Node* temp = NULL;
        
        while(current != NULL) {
            
            temp = current->prev;
            current->prev = current->next;
            current->next = temp;
            current = current->prev;
        }
        if(temp != NULL)
            head = temp->prev;
        
        return head;
    }
};