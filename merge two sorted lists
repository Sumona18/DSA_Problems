/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */

 //basically we are using a dummy node to simplify the merging process. We are iterating through both linked lists and comparing the current nodes of both lists. We are attaching the smaller node to the current node of the merged list and moving the pointer of that list to the next node. Finally, we are attaching the remaining nodes of the non-empty list to the merged list. Time complexity is O(n+m) where n and m are the lengths of the two linked lists, and space complexity is O(1) since we are not using any extra space for merging.
class Solution {
public:
    ListNode* mergeTwoLists(ListNode* list1, ListNode* list2) {
        ListNode dummy(0);
        ListNode* current = &dummy;
        while(list1 != nullptr && list2 != nullptr){
            if(list1->val < list2->val){
                current->next = list1;
                list1 = list1->next;
            }
            else{
                current->next = list2;
                list2 = list2->next;
            }
            current = current->next;
        }
        if(list1 != nullptr)
        current->next = list1;
        else if(list2 != nullptr)
        current->next = list2;
        
        return dummy.next;
    }
};